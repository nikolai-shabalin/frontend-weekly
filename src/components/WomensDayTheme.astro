---
/**
 * Локальная тема к 8 марта для одного выпуска дайджеста.
 * Добавляет праздничный декор и анимацию цветочков по клику на ссылки.
 */
---

<div class="womens-day-bg" aria-hidden="true">
  <span class="womens-day-bg__flower" style="left:6%;top:8%;animation-delay:0s;--drift-x:10px;--drift-y:14px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:18%;top:28%;animation-delay:2.2s;--drift-x:-12px;--drift-y:16px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:31%;top:58%;animation-delay:4.1s;--drift-x:14px;--drift-y:10px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:46%;top:16%;animation-delay:1.4s;--drift-x:-8px;--drift-y:12px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:59%;top:42%;animation-delay:3.6s;--drift-x:11px;--drift-y:18px;">🌼</span>
  <span class="womens-day-bg__flower" style="left:73%;top:70%;animation-delay:5.1s;--drift-x:-10px;--drift-y:11px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:86%;top:24%;animation-delay:2.7s;--drift-x:9px;--drift-y:15px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:12%;top:78%;animation-delay:3.2s;--drift-x:-9px;--drift-y:10px;">🌼</span>
  <span class="womens-day-bg__flower" style="left:64%;top:84%;animation-delay:1.9s;--drift-x:12px;--drift-y:13px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:3%;top:46%;animation-delay:0.9s;--drift-x:8px;--drift-y:11px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:9%;top:62%;animation-delay:4.7s;--drift-x:-13px;--drift-y:14px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:16%;top:12%;animation-delay:5.4s;--drift-x:10px;--drift-y:9px;">🌼</span>
  <span class="womens-day-bg__flower" style="left:24%;top:44%;animation-delay:1.8s;--drift-x:-11px;--drift-y:17px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:28%;top:86%;animation-delay:2.9s;--drift-x:7px;--drift-y:12px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:38%;top:35%;animation-delay:0.6s;--drift-x:13px;--drift-y:16px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:42%;top:66%;animation-delay:3.9s;--drift-x:-9px;--drift-y:10px;">🌼</span>
  <span class="womens-day-bg__flower" style="left:52%;top:8%;animation-delay:4.8s;--drift-x:10px;--drift-y:14px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:57%;top:56%;animation-delay:2.4s;--drift-x:-12px;--drift-y:9px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:67%;top:30%;animation-delay:5.7s;--drift-x:8px;--drift-y:12px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:71%;top:92%;animation-delay:1.1s;--drift-x:-10px;--drift-y:11px;">🌼</span>
  <span class="womens-day-bg__flower" style="left:79%;top:12%;animation-delay:3.1s;--drift-x:14px;--drift-y:15px;">🌸</span>
  <span class="womens-day-bg__flower" style="left:83%;top:52%;animation-delay:4.4s;--drift-x:-8px;--drift-y:18px;">🌷</span>
  <span class="womens-day-bg__flower" style="left:91%;top:73%;animation-delay:2.1s;--drift-x:9px;--drift-y:13px;">🌺</span>
  <span class="womens-day-bg__flower" style="left:95%;top:38%;animation-delay:5.2s;--drift-x:-7px;--drift-y:10px;">🌼</span>
</div>

<div id="flowers-overlay" aria-hidden="true"></div>

<style is:global>
  :root {
    --accent: #d81b60 !important;
    --accent-dark: #ad1457 !important;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --accent: #ff5c8a !important;
      --accent-dark: #ff85ab !important;
    }
  }

  .content {
    position: relative;
  }

  .content h1,
  .content h2 {
    letter-spacing: 0.01em;
  }

  .content h2::before {
    content: '🌸' !important;
    width: auto !important;
    height: auto !important;
    background: none !important;
    position: absolute !important;
    top: -18px !important;
    left: 0 !important;
    font-size: 1rem !important;
    line-height: 1 !important;
  }

  .content blockquote {
    border-left: 3px solid #f06292;
    background: linear-gradient(90deg, rgba(248, 187, 208, 0.22), rgba(255, 255, 255, 0));
    border-radius: 8px;
  }

  @media (prefers-color-scheme: dark) {
    .content blockquote {
      border-left-color: #ff5c8a;
      background: linear-gradient(90deg, rgba(216, 27, 96, 0.2), rgba(0, 0, 0, 0));
    }
  }

  .content ul li::marker {
    color: #e91e63;
  }

  .content a {
    position: relative;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .content a:hover {
    color: #d81b60 !important;
  }

  .content a::after {
    content: ' 🌷';
    opacity: 0;
    transition: opacity 0.2s ease;
    font-size: 0.85em;
  }

  .content a:hover::after {
    opacity: 1;
  }

  @media (prefers-color-scheme: dark) {
    .content a:hover {
      color: #ff85ab !important;
    }
  }

  .womens-day-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .womens-day-bg__flower {
    position: absolute;
    pointer-events: none;
    opacity: 0.33;
    font-size: 1.5rem;
    animation: womens-day-float 7.5s ease-in-out infinite;
  }

  @media (prefers-color-scheme: dark) {
    .womens-day-bg__flower {
      opacity: 0.24;
    }
  }

  @keyframes womens-day-float {
    0% {
      transform: translate(0, 0) rotate(-5deg) scale(0.98);
      opacity: 0.2;
    }
    30% {
      transform: translate(var(--drift-x), calc(var(--drift-y) * -1)) rotate(4deg) scale(1.04);
      opacity: 0.38;
    }
    65% {
      transform: translate(calc(var(--drift-x) * -0.6), var(--drift-y)) rotate(-2deg) scale(1);
      opacity: 0.33;
    }
    100% {
      transform: translate(0, 0) rotate(3deg) scale(0.98);
      opacity: 0.24;
    }
  }

  #flowers-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
  }

  .click-flower {
    position: absolute;
    pointer-events: none;
    animation: flower-burst 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    will-change: transform, opacity;
  }

  @keyframes flower-burst {
    0% {
      transform: translate(0, 0) scale(0.65) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translate(var(--dx), var(--dy)) scale(1.25) rotate(var(--rot));
      opacity: 0;
    }
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('astro:page-load', () => {
    if (window.__womensDayThemeReady) return;
    window.__womensDayThemeReady = true;

    const overlay = document.getElementById('flowers-overlay');
    const content = document.querySelector('.content');
    if (!overlay || !content) return;

    const flowerPool = ['🌸', '🌷', '🌺', '🌼', '💐'];
    const flowerColors = ['#d81b60', '#f06292', '#ec407a', '#ff80ab', '#c2185b'];

    function spawnFlowers(x, y, count = 14) {
      const created = [];
      for (let i = 0; i < count; i++) {
        const flower = document.createElement('span');
        flower.className = 'click-flower';
        flower.textContent = flowerPool[Math.floor(Math.random() * flowerPool.length)];

        const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
        const distance = 50 + Math.random() * 95;
        const dx = Math.cos(angle) * distance;
        const dy = -Math.abs(Math.sin(angle) * distance) - 24 - Math.random() * 52;
        const rot = `${(Math.random() - 0.5) * 120}deg`;

        flower.style.left = `${x}px`;
        flower.style.top = `${y}px`;
        flower.style.setProperty('--dx', `${dx}px`);
        flower.style.setProperty('--dy', `${dy}px`);
        flower.style.setProperty('--rot', rot);
        flower.style.color = flowerColors[Math.floor(Math.random() * flowerColors.length)];
        flower.style.fontSize = `${0.95 + Math.random() * 1.15}rem`;
        flower.style.animationDelay = `${Math.random() * 0.12}s`;

        overlay.appendChild(flower);
        created.push(flower);
      }

      window.setTimeout(() => {
        created.forEach((node) => node.remove());
      }, 1100);
    }

    content.addEventListener('click', (event) => {
      const mouseEvent = event;
      if (mouseEvent.button !== 0 || mouseEvent.metaKey || mouseEvent.ctrlKey || mouseEvent.shiftKey || mouseEvent.altKey) {
        return;
      }

      const target = mouseEvent.target;
      const link = target instanceof Element ? target.closest('a') : null;
      if (!link) return;

      const href = link.getAttribute('href');
      if (!href || href.startsWith('javascript:')) return;

      event.preventDefault();
      spawnFlowers(mouseEvent.clientX, mouseEvent.clientY, 16);

      window.setTimeout(() => {
        const targetAttr = link.getAttribute('target');
        if (targetAttr === '_blank') {
          window.open(href, '_blank', 'noopener');
          return;
        }

        window.location.assign(href);
      }, 520);
    });
  });
</script>
