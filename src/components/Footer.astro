---
const currentYear = new Date().getFullYear();
import SupportBlock from './SupportBlock.astro';
---

<footer class="footer">
  <div class="footer__content">
    <p class="copyright">&copy; {currentYear} Nikolai Shabalin</p>
    <div class="social">
      <a class="social__link" href="https://github.com/nikolai-shabalin/" target="_blank" aria-label="GitHub">
        <span class="sr-only">GitHub</span>
        <svg class="social__icon" viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
          <path fill="currentColor"
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </div>
  </div>

  <SupportBlock />
</footer>

<style>
  .footer {
    padding: var(--space-2xl) var(--space-md);
    margin-top: var(--space-3xl);
    border-top: 3px solid rgba(var(--line), 0.6);
    background:
      radial-gradient(620px 240px at 90% 20%, rgba(var(--accent-yellow-bg-rgb), 0.26), transparent 70%),
      radial-gradient(380px 180px at 10% 100%, rgba(115, 182, 72, 0.16), transparent 72%),
      var(--paper-color);
  }

  .footer__content {
    width: min(100%, var(--content-width));
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    font-size: var(--text-sm);
    color: rgb(var(--muted));
    margin: 0;
    letter-spacing: 0.04em;
    font-family: var(--font-accent);
    text-transform: uppercase;
  }

  .social {
    display: flex;
    gap: var(--space-md);
  }

  .social__link {
    color: rgb(var(--ink-soft));
    transition: color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
    display: flex;
    align-items: center;
    border-bottom: none;
    background: rgba(243, 191, 31, 0.25);
    border: 2px solid rgba(var(--line), 0.35);
    border-radius: 999px;
    width: 2.6rem;
    height: 2.6rem;
    justify-content: center;
  }

  .social__link:hover,
  .social__link:focus-visible {
    color: var(--accent-red);
    background: rgba(243, 191, 31, 0.45);
    transform: translateY(-2px);
  }

  @media (min-width: 720px) {
    .footer__content {
      flex-direction: row;
      gap: 0;
    }
  }
</style>
