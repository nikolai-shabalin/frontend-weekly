---
import { SITE_TITLE } from '../consts';
---

<header class="header">
  <div class="header__content">
    <a href="/" class="logo-link">
      <span class="logo-link__badge">FW</span>
      <span class="logo-link__text">{SITE_TITLE}</span>
    </a>
    <a href="/support" class="support-button">
      Поддержи
    </a>
  </div>
</header>

<style>
  .header {
    padding: var(--space-md);
    backdrop-filter: blur(6px);
  }

  .header__content {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: min(100%, var(--content-width) + 40px);
    margin-inline: auto;
    border: 2px solid rgba(var(--line), 0.65);
    background: linear-gradient(130deg, #f9e070, #f5bf3b 64%, #f2a53f);
    border-radius: 999px;
    padding: 0.5rem 0.65rem;
    box-shadow: var(--shadow-soft);
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: rgb(var(--ink));
    text-decoration: none;
    transition: color 0.2s ease;
    font-size: var(--text-lg);
    min-width: 0;
  }

  .logo-link__badge {
    display: inline-grid;
    place-items: center;
    width: 2.2rem;
    aspect-ratio: 1;
    border-radius: 999px;
    background: var(--accent-red);
    color: #fff7ea;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    line-height: 1;
  }

  .logo-link__text {
    font-family: var(--font-heading);
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .logo-link:hover {
    color: var(--accent-hover);
  }

  .support-button {
    color: #fdf9ee;
    background: var(--accent-green);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 700;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 2px solid rgba(44, 75, 24, 0.25);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .support-button:hover {
    transform: translateY(-1px);
    filter: saturate(110%);
  }

  @media (prefers-color-scheme: dark) {
    .header__content {
      border-color: rgba(var(--line), 0.8);
      background: linear-gradient(130deg, #33251c, #422d20 64%, #56372a);
    }

    .support-button {
      color: rgb(var(--ink));
      background: var(--accent);
      border-color: rgba(var(--accent-rgb), 0.4);
    }
  }

  @media (max-width: 720px) {
    .header {
      padding-inline: var(--space-sm);
    }

    .logo-link__text {
      max-width: 11rem;
    }
  }
</style>
