---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { createHash } from 'node:crypto';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('digest');
	return posts.map((post) => {
		const postId = post.id;
		const slug = post.data.isHidden
			? `${postId}-${createHash('md5').update(postId).digest('hex').substring(0, 8)}`
			: postId;

		return {
			params: { slug },
			props: { ...post, originalSlug: postId },
		};
	});
}

type Props = CollectionEntry<'digest'> & {
	originalSlug: string;
};

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} slug={post.originalSlug}>
	<Content />
</BlogPost>
