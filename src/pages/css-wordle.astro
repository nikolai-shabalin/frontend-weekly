---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'CSS Wordle';
const description = 'Wordle по CSS-свойствам и значениям из Frontend Weekly.';
---

<!doctype html>
<html lang="ru">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        padding-top: var(--space-xl);
      }

      .wordle {
        position: relative;
        width: min(100%, 1280px);
        margin-inline: auto;
        display: grid;
        gap: var(--space-lg);
      }

      .wordle.htmlacademy {
        --ha-blue: #0b73ff;
        --ha-blue-deep: #063f99;
        --ha-blue-soft: #dcedff;
        --ha-ink: #071f45;
        padding: var(--space-lg);
        color: var(--ha-ink);
        background:
          radial-gradient(circle at 12% 10%, rgba(35, 134, 255, 0.22), transparent 26rem),
          linear-gradient(135deg, #f8fbff 0%, #dcedff 48%, #b8d9ff 100%);
        border: 2px solid rgba(11, 115, 255, 0.2);
        border-radius: var(--radius-lg);
      }

      .wordle__header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: end;
        gap: var(--space-md);
        padding-bottom: var(--space-md);
        border-bottom: 3px dashed rgba(var(--line), 0.56);
      }

      .wordle__eyebrow {
        display: inline-flex;
        width: fit-content;
        margin-bottom: var(--space-sm);
        padding: 0.24rem 0.62rem;
        color: var(--accent-dark);
        background: rgba(243, 191, 31, 0.36);
        border: 1px solid rgba(var(--line), 0.45);
        border-radius: 999px 999px 999px 0;
        font-family: var(--font-accent);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .wordle__title {
        margin: 0;
        font-size: var(--text-5xl);
      }

      .wordle-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
        gap: var(--space-lg);
        align-items: start;
      }

      .thanks-panel,
      .leaderboard {
        display: grid;
        gap: var(--space-lg);
        padding: var(--space-lg);
        background: var(--paper-color);
        border: 2px solid rgba(var(--line), 0.52);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
      }

      .wordle.htmlacademy .leaderboard,
      .wordle.htmlacademy .thanks-panel {
        background: rgba(255, 255, 255, 0.9);
        border-color: rgba(11, 115, 255, 0.28);
        box-shadow: 0 18px 40px rgba(6, 63, 153, 0.12);
      }

      .wordle.htmlacademy .wordle__header {
        border-bottom-color: rgba(11, 115, 255, 0.34);
      }

      .wordle.htmlacademy .wordle__eyebrow,
      .wordle.htmlacademy .leaderboard__score {
        color: var(--ha-blue-deep);
      }

      .wordle.htmlacademy .wordle__eyebrow {
        background: rgba(11, 115, 255, 0.12);
        border-color: rgba(11, 115, 255, 0.28);
      }

      .thanks-panel__title,
      .leaderboard__title {
        margin: 0;
        font-size: var(--text-2xl);
      }

      .thanks-panel__text {
        margin: 0;
        color: rgb(var(--ink-soft));
        font-size: var(--text-lg);
        line-height: 1.65;
      }

      .thanks-panel__winners {
        display: grid;
        gap: var(--space-sm);
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .thanks-panel__winner {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--space-sm);
        align-items: center;
        padding: 0.9rem 1rem;
        background: rgba(243, 191, 31, 0.18);
        border: 2px solid rgba(var(--line), 0.4);
        border-radius: var(--radius-md);
      }

      .thanks-panel__place {
        display: grid;
        place-items: center;
        width: 2.25rem;
        aspect-ratio: 1;
        color: #fff9ec;
        background: var(--accent-dark);
        border-radius: 999px;
        font-family: var(--font-accent);
        font-size: var(--text-sm);
        font-weight: 800;
      }

      .thanks-panel__name {
        margin: 0;
        color: rgb(var(--ink));
        font-size: var(--text-lg);
        font-weight: 800;
        line-height: 1.2;
      }

      .thanks-panel__note {
        margin: 0.15rem 0 0;
        color: rgb(var(--ink-soft));
        font-size: var(--text-sm);
      }

      .htmlacademy-logo {
        position: fixed;
        right: max(var(--space-md), env(safe-area-inset-right));
        bottom: max(var(--space-md), env(safe-area-inset-bottom));
        z-index: 20;
        display: none;
        width: min(12rem, calc(100vw - 2rem));
        padding: 0.75rem 0.9rem;
        background: #ffffff;
        border: 2px solid rgba(11, 115, 255, 0.24);
        border-radius: var(--radius-md);
        box-shadow: 0 18px 42px rgba(6, 63, 153, 0.24);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .htmlacademy-logo:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 48px rgba(6, 63, 153, 0.28);
      }

      .htmlacademy-logo img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 0;
      }

      .wordle.htmlacademy .htmlacademy-logo {
        display: block;
      }

      .leaderboard {
        position: sticky;
        top: var(--space-md);
      }

      .leaderboard__table {
        font-size: 16px;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 0.45rem;
      }

      .leaderboard__table th {
        padding: 0 0.6rem 0.1rem;
        color: rgb(var(--muted));
        font-family: var(--font-accent);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-align: left;
        text-transform: uppercase;
      }

      .leaderboard__table th:last-child {
        text-align: right;
      }

      .leaderboard__gap {
        padding: 0.75rem 0.6rem;
        color: rgb(var(--muted));
        font-family: var(--font-accent);
        text-align: center;
      }

      @media (prefers-color-scheme: dark) {
        .leaderboard,
        .thanks-panel {
          border-color: rgba(var(--line), 0.58);
        }

        .wordle__eyebrow {
          color: var(--accent-yellow);
          background: rgba(var(--accent-yellow-bg-rgb), 0.16);
          border-color: rgba(var(--line), 0.52);
        }

        .thanks-panel__winner {
          background: rgba(var(--accent-yellow-bg-rgb), 0.14);
        }
      }

      @media (max-width: 760px) {
        .wordle__header {
          grid-template-columns: 1fr;
          align-items: start;
        }

        .wordle__title {
          font-size: var(--text-4xl);
        }

        .wordle-shell {
          grid-template-columns: 1fr;
        }

        .leaderboard {
          position: static;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="wordle" data-wordle aria-labelledby="css-wordle-title">
        <a class="htmlacademy-logo" href="https://htmlacademy.ru/" target="_blank" rel="noreferrer" aria-label="HTML Academy">
          <img src="/images/htmlacademy-logo.svg" width="140"  alt="HTML Academy" />
        </a>

        <div class="wordle__header">
          <div>
            <span class="wordle__eyebrow">Выпуск 50</span>
            <h1 class="wordle__title" id="css-wordle-title">CSS Wordle</h1>
          </div>
        </div>

        <div class="wordle-shell">
          <section class="thanks-panel" aria-labelledby="thanks-title">
            <h2 class="thanks-panel__title" id="thanks-title">Спасибо за игру!</h2>
            <p class="thanks-panel__text">
              Спасибо всем игрокам CSS Wordle за участие, азарт и внимание к CSS-фичам.
              Было здорово видеть, как вы проходили словарь, возвращались за новыми словами.
            </p>
            <p>С вами был пятидесятый выпуск. Встретимся в сотом выпуске 😁</p>
            <p class="thanks-panel__text">
              Отдельная благодарность первым трём призёрам:
            </p>
            <ol class="thanks-panel__winners">
              <li class="thanks-panel__winner">
                <span class="thanks-panel__place">#1</span>
                <div>
                  <p class="thanks-panel__name">Boris</p>
                  <p class="thanks-panel__note">27 баллов и первое место в CSS Wordle.</p>
                </div>
              </li>
              <li class="thanks-panel__winner">
                <span class="thanks-panel__place">#2</span>
                <div>
                  <p class="thanks-panel__name">KoryakinaSvetlana</p>
                  <p class="thanks-panel__note">15 баллов и второе место.</p>
                </div>
              </li>
              <li class="thanks-panel__winner">
                <span class="thanks-panel__place">#3</span>
                <div>
                  <p class="thanks-panel__name">DarthVitalus</p>
                  <p class="thanks-panel__note">10 баллов и третье место.</p>
                </div>
              </li>
            </ol>
          </section>

          <aside class="leaderboard" aria-labelledby="leaderboard-title">
            <h2 class="leaderboard__title" id="leaderboard-title">Рейтинг</h2>
            <table class="leaderboard__table">
              <thead>
                <tr>
                  <th scope="col">Место</th>
                  <th scope="col">Игрок</th>
                  <th scope="col">Баллы</th>
                </tr>
              </thead>
              <tbody>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#1</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/Frontend-Sisyphus" target="_blank" rel="noreferrer">Boris</a>
                  </td>
                  <td><span class="leaderboard__score">27</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#2</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/KoryakinaSvetlana" target="_blank" rel="noreferrer">KoryakinaSvetlana</a>
                  </td>
                  <td><span class="leaderboard__score">15</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#3</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/DarthVitalus" target="_blank" rel="noreferrer">DarthVitalus</a>
                  </td>
                  <td><span class="leaderboard__score">10</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#4</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/Balkanskiy" target="_blank" rel="noreferrer">Alex</a>
                  </td>
                  <td><span class="leaderboard__score">4</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#5</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/firefoxic" target="_blank" rel="noreferrer">firefoxic</a>
                  </td>
                  <td><span class="leaderboard__score">4</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#6</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/GryphM" target="_blank" rel="noreferrer">Maxim Gryph</a>
                  </td>
                  <td><span class="leaderboard__score">3</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#7</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/nikolai-shabalin" target="_blank" rel="noreferrer">Nikolai Shabalin</a>
                  </td>
                  <td><span class="leaderboard__score">3</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#8</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/TNikolay" target="_blank" rel="noreferrer">Nikolay Tiushkov</a>
                  </td>
                  <td><span class="leaderboard__score">2</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#9</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/valdrus" target="_blank" rel="noreferrer">valdrus</a>
                  </td>
                  <td><span class="leaderboard__score">1</span></td>
                </tr>
                <tr class="leaderboard__row">
                  <td><span class="leaderboard__rank">#10</span></td>
                  <td>
                    <a class="leaderboard__link" href="https://github.com/Fostenslave" target="_blank" rel="noreferrer">Вячеслав</a>
                  </td>
                  <td><span class="leaderboard__score">0</span></td>
                </tr>
              </tbody>
            </table>
          </aside>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
