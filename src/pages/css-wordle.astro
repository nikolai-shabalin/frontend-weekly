---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'CSS Wordle';
const description = 'Wordle по CSS-свойствам и значениям из Frontend Weekly.';
const apiBaseUrl = import.meta.env.PUBLIC_CSS_WORDLE_API_URL ?? 'http://localhost:8787';
---

<!doctype html>
<html lang="ru">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        padding-top: var(--space-xl);
      }

      .wordle {
        position: relative;
        width: min(100%, 1280px);
        margin-inline: auto;
        display: grid;
        gap: var(--space-lg);
      }

      .wordle.htmlacademy {
        --ha-blue: #0b73ff;
        --ha-blue-deep: #063f99;
        --ha-blue-soft: #dcedff;
        --ha-ink: #071f45;
        padding: var(--space-lg);
        color: var(--ha-ink);
        background:
          radial-gradient(circle at 12% 10%, rgba(35, 134, 255, 0.22), transparent 26rem),
          linear-gradient(135deg, #f8fbff 0%, #dcedff 48%, #b8d9ff 100%);
        border: 2px solid rgba(11, 115, 255, 0.2);
        border-radius: var(--radius-lg);
      }

      .wordle__header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: end;
        gap: var(--space-md);
        padding-bottom: var(--space-md);
        border-bottom: 3px dashed rgba(var(--line), 0.56);
      }

      .wordle__eyebrow {
        display: inline-flex;
        width: fit-content;
        margin-bottom: var(--space-sm);
        padding: 0.24rem 0.62rem;
        color: var(--accent-dark);
        background: rgba(243, 191, 31, 0.36);
        border: 1px solid rgba(var(--line), 0.45);
        border-radius: 999px 999px 999px 0;
        font-family: var(--font-accent);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .wordle__title {
        margin: 0;
        font-size: var(--text-5xl);
      }

      .wordle__meta {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-xs);
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .wordle__meta-item {
        min-width: 7.5rem;
        padding: 0.6rem 0.75rem;
        background: var(--paper-color);
        border: 2px solid rgba(var(--line), 0.48);
        border-radius: var(--radius-sm);
        font-family: var(--font-accent);
        font-size: var(--text-sm);
        line-height: 1.15;
        text-transform: uppercase;
      }

      .wordle__meta-value {
        display: block;
        margin-top: 0.2rem;
        color: var(--accent-dark);
        font-family: var(--font-heading);
        font-size: var(--text-lg);
        text-transform: none;
      }

      .wordle__actions {
        display: flex;
        gap: var(--space-sm);
        justify-content: end;
      }

      .wordle__actions[hidden] {
        display: none;
      }

      .button {
        min-height: 2.75rem;
        padding: 0.55rem 1rem;
        color: #fff9ec;
        background: linear-gradient(120deg, var(--accent-dark), var(--accent));
        border: 2px solid rgba(110, 43, 10, 0.22);
        border-radius: 999px;
        font: 800 var(--text-sm) / 1 var(--font-body);
        cursor: pointer;
        transition: transform 0.2s ease, filter 0.2s ease;
      }

      .button:hover {
        transform: translateY(-1px);
        filter: saturate(112%);
      }

      .wordle.htmlacademy .button {
        color: #ffffff;
        background: linear-gradient(120deg, var(--ha-blue-deep), var(--ha-blue));
        border-color: rgba(6, 63, 153, 0.34);
        box-shadow: 0 12px 28px rgba(11, 115, 255, 0.2);
      }

      .game {
        display: grid;
        gap: var(--space-lg);
        padding: var(--space-lg);
        background: var(--paper-color);
        border: 2px solid rgba(var(--line), 0.52);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
      }

      .game[hidden] {
        display: none;
      }

      .wordle-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
        gap: var(--space-lg);
        align-items: start;
      }

      .wordle-main,
      .leaderboard,
      .auth-panel {
        display: grid;
        gap: var(--space-lg);
      }

      .auth-panel,
      .leaderboard {
        padding: var(--space-lg);
        background: var(--paper-color);
        border: 2px solid rgba(var(--line), 0.52);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
      }

      .wordle.htmlacademy .auth-panel,
      .wordle.htmlacademy .leaderboard,
      .wordle.htmlacademy .game,
      .wordle.htmlacademy .rules,
      .wordle.htmlacademy .user-panel,
      .wordle.htmlacademy .wordle__meta-item {
        background: rgba(255, 255, 255, 0.9);
        border-color: rgba(11, 115, 255, 0.28);
        box-shadow: 0 18px 40px rgba(6, 63, 153, 0.12);
      }

      .wordle.htmlacademy .wordle__header {
        border-bottom-color: rgba(11, 115, 255, 0.34);
      }

      .wordle.htmlacademy .wordle__eyebrow,
      .wordle.htmlacademy .wordle__meta-value,
      .wordle.htmlacademy .leaderboard__score,
      .wordle.htmlacademy .final-panel__eyebrow,
      .wordle.htmlacademy .final-panel__score {
        color: var(--ha-blue-deep);
      }

      .wordle.htmlacademy .wordle__eyebrow {
        background: rgba(11, 115, 255, 0.12);
        border-color: rgba(11, 115, 255, 0.28);
      }

      .auth-panel[hidden],
      .wordle-main[hidden] {
        display: none;
      }

      .auth-panel__title,
      .leaderboard__title {
        margin: 0;
        font-size: var(--text-2xl);
      }

      .auth-panel__text {
        margin: 0;
        color: rgb(var(--ink-soft));
        font-size: var(--text-base);
      }

      .github-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        min-height: 3rem;
        padding: 0.65rem 1rem;
        color: #fff;
        background: #24292f;
        border: 2px solid #1b1f24;
        border-radius: 8px;
        font: 800 var(--text-sm) / 1 var(--font-body);
        text-decoration: none;
        transition: transform 0.2s ease, filter 0.2s ease;
      }

      .github-button:hover {
        color: #fff;
        transform: translateY(-1px);
        filter: brightness(1.08);
      }

      .github-button svg {
        width: 1.3rem;
        height: 1.3rem;
        flex: 0 0 auto;
      }

      .user-panel {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-sm);
        padding: 0.75rem;
        background: rgba(252, 248, 237, 0.72);
        border: 2px solid rgba(var(--line), 0.42);
        border-radius: var(--radius-md);
      }

      .user-panel[hidden] {
        display: none;
      }

      .user-panel__avatar {
        width: 2.35rem;
        aspect-ratio: 1;
        border-radius: 999px;
        border: 2px solid rgba(var(--line), 0.52);
      }

      .user-panel__name {
        margin: 0;
        color: rgb(var(--ink));
        font-size: var(--text-sm);
        font-weight: 800;
        line-height: 1.1;
      }

      .user-panel__link {
        color: rgb(var(--muted));
        font-family: var(--font-accent);
        font-size: var(--text-xs);
      }

      .logout-button {
        margin-left: auto;
        min-height: 2.2rem;
        padding: 0.35rem 0.7rem;
        color: rgb(var(--ink-soft));
        background: transparent;
        border: 2px solid rgba(var(--line), 0.52);
        border-radius: 8px;
        font: 700 var(--text-xs) / 1 var(--font-body);
        cursor: pointer;
      }

      .htmlacademy-logo {
        position: fixed;
        right: max(var(--space-md), env(safe-area-inset-right));
        bottom: max(var(--space-md), env(safe-area-inset-bottom));
        z-index: 20;
        display: none;
        width: min(12rem, calc(100vw - 2rem));
        padding: 0.75rem 0.9rem;
        background: #ffffff;
        border: 2px solid rgba(11, 115, 255, 0.24);
        border-radius: var(--radius-md);
        box-shadow: 0 18px 42px rgba(6, 63, 153, 0.24);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .htmlacademy-logo:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 48px rgba(6, 63, 153, 0.28);
      }

      .htmlacademy-logo img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 0;
      }

      .wordle.htmlacademy .htmlacademy-logo {
        display: block;
      }

      .leaderboard {
        position: sticky;
        top: var(--space-md);
      }

      .leaderboard__table {
        font-size: 16px;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 0.45rem;
      }

      .leaderboard__table th {
        padding: 0 0.6rem 0.1rem;
        color: rgb(var(--muted));
        font-family: var(--font-accent);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-align: left;
        text-transform: uppercase;
      }

      .leaderboard__table th:last-child {
        text-align: right;
      }

      .leaderboard__row td {
        padding: 0.55rem 0.5rem;
        background: rgba(252, 248, 237, 0.72);
        border-block: 1px solid rgba(var(--line), 0.38);
        font-size: 0.82rem;
      }

      .leaderboard__row td:first-child {
        width: 4.5rem;
        padding-left: 0.6rem;
        border-left: 1px solid rgba(var(--line), 0.38);
        border-radius: 8px 0 0 8px;
      }

      .leaderboard__row td:last-child {
        width: 5.8rem;
        padding-right: 0.6rem;
        border-right: 1px solid rgba(var(--line), 0.38);
        border-radius: 0 8px 8px 0;
      }

      .leaderboard__row--current td {
        background: rgba(115, 182, 72, 0.18);
        border-color: rgba(115, 182, 72, 0.46);
      }

      .leaderboard__rank {
        display: inline-grid;
        place-items: center;
        min-height: 2rem;
        color: rgb(var(--ink));
        background: rgba(243, 191, 31, 0.24);
        border: 1px solid rgba(139, 98, 18, 0.2);
        border-radius: 8px;
        font-family: var(--font-accent);
        font-size: 0.74rem;
      }

      .leaderboard__link {
        overflow: hidden;
        color: rgb(var(--ink));
        font-weight: 800;
        text-decoration: none;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .leaderboard__score {
        display: inline-grid;
        place-items: center end;
        min-height: 2rem;
        padding: 0 0.45rem;
        color: var(--accent-dark);
        background: rgba(115, 182, 72, 0.16);
        border: 1px solid rgba(75, 132, 44, 0.22);
        border-radius: 8px;
        font-family: var(--font-heading);
        font-size: 0.82rem;
        text-align: right;
        white-space: nowrap;
      }

      .leaderboard__gap {
        padding: 0.75rem 0.6rem;
        color: rgb(var(--muted));
        font-family: var(--font-accent);
        text-align: center;
      }

      .rules {
        background: rgba(252, 248, 237, 0.72);
        border: 2px solid rgba(var(--line), 0.48);
        border-radius: var(--radius-md);
        overflow: hidden;
      }

      .rules[hidden] {
        display: none;
      }

      .rules__summary {
        padding: 0.8rem 1rem;
        color: rgb(var(--ink));
        font-family: var(--font-accent);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        cursor: pointer;
      }

      .rules__content {
        padding: 0 var(--space-lg) var(--space-md);
        color: rgb(var(--ink-soft));
        font-size: var(--text-sm);
      }

      .rules__content p {
        margin-bottom: var(--space-sm);
      }

      .rules__content ul {
        margin: 0;
        padding-left: var(--space-lg);
      }

      .final-panel {
        position: relative;
        display: grid;
        gap: var(--space-sm);
        padding: var(--space-xl);
        min-height: 22rem;
        place-content: center;
        text-align: center;
        background:
          linear-gradient(135deg, rgba(115, 182, 72, 0.2), rgba(243, 191, 31, 0.26)),
          var(--paper-color);
        border: 2px solid rgba(115, 182, 72, 0.46);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
      }

      .final-panel::before,
      .final-panel::after {
        position: absolute;
        top: 50%;
        font-size: clamp(2.5rem, 7vw, 5rem);
        transform: translateY(-50%);
        content: '🎉';
      }

      .final-panel::before {
        left: var(--space-lg);
      }

      .final-panel::after {
        right: var(--space-lg);
      }

      .final-panel[hidden] {
        display: none;
      }

      .final-panel__eyebrow {
        margin: 0;
        color: var(--accent-dark);
        font-family: var(--font-accent);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .final-panel__title {
        margin: 0;
        font-size: var(--text-4xl);
      }

      .final-panel__text {
        max-width: 34rem;
        margin: 0 auto;
        color: rgb(var(--ink-soft));
        font-size: var(--text-lg);
      }

      .final-panel__score {
        color: var(--accent-dark);
        font-family: var(--font-heading);
        font-size: var(--text-3xl);
      }

      .status {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-sm);
        min-height: 55px;
        margin: 0;
        padding: 0.55rem 0.75rem;
        color: rgb(var(--ink-soft));
        background: rgba(243, 191, 31, 0.22);
        border: 1px solid rgba(var(--line), 0.42);
        border-radius: var(--radius-sm);
        font-family: var(--font-accent);
        font-size: var(--text-sm);
      }

      .status[data-tone='success'] {
        color: #183d1f;
        background: rgba(115, 182, 72, 0.24);
        border-color: rgba(115, 182, 72, 0.52);
      }

      .wordle.htmlacademy .status {
        color: var(--ha-ink);
        background: rgba(11, 115, 255, 0.1);
        border-color: rgba(11, 115, 255, 0.26);
      }

      .wordle.htmlacademy .status[data-tone='success'] {
        color: #05336f;
        background: rgba(11, 115, 255, 0.16);
        border-color: rgba(11, 115, 255, 0.38);
      }

      .status[data-tone='danger'] {
        color: #5b1612;
        background: rgba(215, 62, 49, 0.16);
        border-color: rgba(215, 62, 49, 0.38);
      }

      .status__text {
        min-width: 0;
      }

      .status__text:empty::before {
        content: '\00a0';
      }

      .status__next {
        flex: 0 0 auto;
        min-height: 2.15rem;
        padding: 0.42rem 0.78rem;
        font-size: var(--text-xs);
      }

      .status__next[hidden] {
        display: none;
      }

      .board-scroll {
        display: flex;
        justify-content: center;
        overflow-x: auto;
        padding-bottom: var(--space-xs);
        scrollbar-color: rgba(var(--line), 0.7) transparent;
      }

      .board {
        --word-length: 5;
        display: grid;
        gap: 0.45rem;
        width: max-content;
        min-width: min(100%, calc(var(--word-length) * 2rem));
      }

      :global(.board__row) {
        display: grid;
        grid-template-columns: repeat(var(--word-length), 2rem);
        gap: 0.35rem;
      }

      :global(.tile) {
        display: grid;
        place-items: center;
        width: 2rem;
        aspect-ratio: 1;
        color: rgb(var(--ink));
        background: rgba(252, 248, 237, 0.72);
        border: 2px solid rgba(var(--line), 0.56);
        border-radius: 8px;
        font-family: var(--font-accent);
        font-size: 1rem;
        font-weight: 700;
        line-height: 1;
        text-transform: uppercase;
      }

      :global(.tile[data-state='filled']) {
        border-color: rgba(var(--ink), 0.38);
      }

      :global(.tile[data-state='correct']) {
        color: #102315;
        background: #73b648;
        border-color: #5d9838;
      }

      .wordle.htmlacademy :global(.tile[data-state='correct']) {
        color: #ffffff;
        background: var(--ha-blue);
        border-color: var(--ha-blue-deep);
      }

      :global(.tile[data-state='present']) {
        color: #2c1c06;
        background: #f3bf1f;
        border-color: #d99f14;
      }

      :global(.tile[data-state='absent']) {
        color: #fff9ec;
        background: rgb(var(--muted));
        border-color: rgba(var(--muted), 0.4);
      }

      .keyboard {
        display: grid;
        gap: 0.45rem;
      }

      :global(.keyboard__row) {
        display: flex;
        justify-content: center;
        gap: 0.35rem;
      }

      :global(.key) {
        display: inline-grid;
        place-items: center;
        min-width: 2rem;
        min-height: 2.6rem;
        padding: 0 0.48rem;
        color: rgb(var(--ink));
        background: rgba(243, 191, 31, 0.28);
        border: 2px solid rgba(var(--line), 0.52);
        border-radius: 8px;
        font-family: var(--font-accent);
        font-size: var(--text-sm);
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        text-transform: uppercase;
        transition: transform 0.15s ease, background-color 0.15s ease;
      }

      :global(.key:hover) {
        transform: translateY(-1px);
        background: rgba(243, 191, 31, 0.46);
      }

      :global(.key--wide) {
        min-width: 4.7rem;
        font-family: var(--font-body);
        font-size: 0.8rem;
      }

      :global(.key[data-state='correct']) {
        color: #102315;
        background: #73b648;
        border-color: #5d9838;
      }

      .wordle.htmlacademy :global(.key[data-state='correct']) {
        color: #ffffff;
        background: var(--ha-blue);
        border-color: var(--ha-blue-deep);
      }

      :global(.key[data-state='present']) {
        color: #2c1c06;
        background: #f3bf1f;
        border-color: #d99f14;
      }

      :global(.key[data-state='absent']) {
        color: #fff9ec;
        background: rgb(var(--muted));
        border-color: rgba(var(--muted), 0.4);
      }

      @media (prefers-color-scheme: dark) {
        .wordle__meta-item,
        .game,
        .rules,
        .final-panel,
        .auth-panel,
        .leaderboard,
        .user-panel {
          border-color: rgba(var(--line), 0.58);
        }

        .wordle__eyebrow {
          color: var(--accent-yellow);
          background: rgba(var(--accent-yellow-bg-rgb), 0.16);
          border-color: rgba(var(--line), 0.52);
        }

        .rules,
        .final-panel,
        .user-panel {
          background: rgba(17, 22, 21, 0.28);
        }

        .status[data-tone='success'] {
          color: #dff9e4;
          background: rgba(127, 216, 169, 0.14);
          border-color: rgba(127, 216, 169, 0.34);
        }

        .status[data-tone='danger'] {
          color: #ffd7d2;
          background: rgba(255, 130, 120, 0.13);
          border-color: rgba(255, 130, 120, 0.34);
        }

        :global(.tile) {
          background: rgba(17, 22, 21, 0.34);
        }

        :global(.key) {
          background: rgba(var(--accent-yellow-bg-rgb), 0.14);
        }

        :global(.key:hover) {
          background: rgba(var(--accent-yellow-bg-rgb), 0.22);
        }
      }

      @media (max-width: 760px) {
        .wordle__header {
          grid-template-columns: 1fr;
          align-items: start;
        }

        .wordle__title {
          font-size: var(--text-4xl);
        }

        .wordle__actions {
          justify-content: start;
        }

        .game {
          padding: var(--space-md);
        }

        .wordle-shell {
          grid-template-columns: 1fr;
        }

        .leaderboard {
          position: static;
        }

        .rules__content {
          padding-inline: var(--space-md);
        }

        :global(.board__row) {
          grid-template-columns: repeat(var(--word-length), 1.7rem);
          gap: 0.28rem;
        }

        :global(.tile) {
          width: 1.7rem;
          font-size: 0.86rem;
          border-radius: 7px;
        }

        :global(.keyboard__row) {
          gap: 0.25rem;
        }

        :global(.key) {
          min-width: 1.75rem;
          min-height: 2.35rem;
          padding-inline: 0.34rem;
        }

        :global(.key--wide) {
          min-width: 3.8rem;
        }
      }

      @media (max-width: 420px) {
        .keyboard {
          gap: 0.35rem;
        }

        :global(.key) {
          min-width: 1.45rem;
          min-height: 2.15rem;
          padding-inline: 0.24rem;
          font-size: 0.8rem;
        }

        :global(.key--wide) {
          min-width: 3.2rem;
          font-size: 0.7rem;
        }

        .final-panel::before,
        .final-panel::after {
          position: static;
          transform: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="wordle" data-wordle aria-labelledby="css-wordle-title">
        <a class="htmlacademy-logo" href="https://htmlacademy.ru/" target="_blank" rel="noreferrer" aria-label="HTML Academy">
          <img src="/images/htmlacademy-logo.svg" width="140"  alt="HTML Academy" />
        </a>

        <div class="wordle__header">
          <div>
            <span class="wordle__eyebrow">Выпуск 50</span>
            <h1 class="wordle__title" id="css-wordle-title">CSS Wordle</h1>
          </div>
          <div class="wordle__actions" data-wordle-actions>
            <button class="button" type="button" data-new-game>Следующее слово</button>
          </div>
        </div>

        <ul class="wordle__meta" aria-label="Параметры загадки">
          <li class="wordle__meta-item">
            Символов
            <span class="wordle__meta-value" data-word-length>0</span>
          </li>
          <li class="wordle__meta-item">
            Попыток
            <span class="wordle__meta-value" data-attempts>0/6</span>
          </li>
          <li class="wordle__meta-item">
            Угаданных/словарь
            <span class="wordle__meta-value" data-progress-count>...</span>
          </li>
        </ul>

        <div class="wordle-shell">
          <div>
            <section class="auth-panel" data-auth-panel>
              <h2 class="auth-panel__title">Вход через GitHub</h2>
              <p class="auth-panel__text">
                Чтобы участвовать в CSS Wordle и попасть в рейтинг, войдите через GitHub.
              </p>
              <a class="github-button" data-github-login href="#">
                <svg viewBox="0 0 16 16" aria-hidden="true">
                  <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                GitHub
              </a>
            </section>

            <div class="wordle-main" data-wordle-main hidden>
              <div class="user-panel" data-user-panel hidden>
                <img class="user-panel__avatar" data-user-avatar src="" alt="" />
                <div>
                  <p class="user-panel__name" data-user-name></p>
                  <a class="user-panel__link" data-user-link href="#" target="_blank" rel="noreferrer"></a>
                </div>
                <button class="logout-button" type="button" data-logout>Выйти</button>
              </div>

              <section class="final-panel" data-final-panel hidden>
                <p class="final-panel__eyebrow">Словарь закрыт</p>
                <h2 class="final-panel__title">Поздравляем!</h2>
                <p class="final-panel__text" data-final-text>
                  Ты какой-то невероятный и прошёл игру до конца. Поздравляю ты угадал все слова.
                </p>
              </section>

              <details class="rules" data-rules>
                <summary class="rules__summary">Правила</summary>
                <div class="rules__content">
                  <p>
                    Это классическая игра Wordle, но с CSS-фичами вместо обычных слов.
                    В загадках встречаются слова от 4 до 10 символов.
                  </p>
                  <ul>
                    <li>Начните вводить CSS-фичи на английской раскладке.</li>
                    <li>Вводятся только буквы, цифры и дефис.</li>
                    <li>Отправить можно только CSS-фичу из словаря. Случайный набор букв не пройдет. Также не подойдёт простое английское слово.</li>
                    <li>Зеленая клетка означает точное совпадение символа и позиции.</li>
                    <li>Желтая клетка означает, что символ есть в ответе, но стоит в другом месте.</li>
                    <li>Серая клетка означает, что символа нет в ответе.</li>
                    <li>На каждую загадку дается 6 попыток.</li>
                  </ul>
                </div>
              </details>

              <div class="game" data-game>
                <div class="status" data-status data-tone="" role="status" aria-live="polite">
                  <span class="status__text" data-status-text></span>
                  <button class="button status__next" type="button" data-status-next hidden>
                    Следующее слово
                  </button>
                </div>
                <div class="board-scroll" tabindex="0" aria-label="Игровое поле">
                  <div class="board" data-board></div>
                </div>
                <div class="keyboard" data-keyboard aria-label="Клавиатура"></div>
              </div>
            </div>
          </div>

          <aside class="leaderboard" aria-labelledby="leaderboard-title">
            <h2 class="leaderboard__title" id="leaderboard-title">Рейтинг</h2>
            <table class="leaderboard__table">
              <thead>
                <tr>
                  <th scope="col">Место</th>
                  <th scope="col">Игрок</th>
                  <th scope="col">Баллы</th>
                </tr>
              </thead>
              <tbody data-leaderboard>
                <tr>
                  <td class="leaderboard__gap" colspan="3">Загружаю...</td>
                </tr>
              </tbody>
            </table>
          </aside>
        </div>
      </section>
    </main>
    <Footer />

    <script is:inline define:vars={{ apiBaseUrl }} data-astro-rerun>
      const MAX_ATTEMPTS = 6;
      const VALID_INPUT = /^[a-z0-9-]$/;
      const KEY_ROWS = [
        ['q', 'w', 'e', 'r', 't', 'y', 'u', 'i', 'o', 'p'],
        ['a', 's', 'd', 'f', 'g', 'h', 'j', 'k', 'l'],
        ['enter', 'z', 'x', 'c', 'v', 'b', 'n', 'm', 'backspace'],
        ['-', '2', '4', '5'],
      ];
      const STATE_RANK = {
        absent: 1,
        present: 2,
        correct: 3,
      };
      const UUID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

      const board = document.querySelector('[data-board]');
      const wordle = document.querySelector('[data-wordle]');
      const keyboard = document.querySelector('[data-keyboard]');
      const status = document.querySelector('[data-status]');
      const statusText = document.querySelector('[data-status-text]');
      const statusNextButton = document.querySelector('[data-status-next]');
      const wordLength = document.querySelector('[data-word-length]');
      const attempts = document.querySelector('[data-attempts]');
      const progressCount = document.querySelector('[data-progress-count]');
      const wordleActions = document.querySelector('[data-wordle-actions]');
      const newGameButton = document.querySelector('[data-new-game]');
      const authPanel = document.querySelector('[data-auth-panel]');
      const githubLogin = document.querySelector('[data-github-login]');
      const wordleMain = document.querySelector('[data-wordle-main]');
      const userPanel = document.querySelector('[data-user-panel]');
      const finalPanel = document.querySelector('[data-final-panel]');
      const finalText = document.querySelector('[data-final-text]');
      const rules = document.querySelector('[data-rules]');
      const gamePanel = document.querySelector('[data-game]');
      const userAvatar = document.querySelector('[data-user-avatar]');
      const userName = document.querySelector('[data-user-name]');
      const userLink = document.querySelector('[data-user-link]');
      const logoutButton = document.querySelector('[data-logout]');
      const leaderboard = document.querySelector('[data-leaderboard]');
      window.cssWordleAbortController?.abort();

      const controller = new AbortController();
      window.cssWordleAbortController = controller;

      let gameUuid = '';
      let wordUuid = '';
      let answerLength = 0;
      let currentGuess = '';
      let guesses = [];
      let gameOver = false;
      let isSubmitting = false;
      let keyStates = {};

      function getGameUuidFromUrl() {
        const game = new URL(location.href).searchParams.get('game');

        return UUID_PATTERN.test(game ?? '') ? game : '';
      }

      function setGameUuidInUrl(nextGameUuid, mode = 'replace') {
        const url = new URL(location.href);

        if (nextGameUuid) {
          url.searchParams.set('game', nextGameUuid);
        } else {
          url.searchParams.delete('game');
        }

        history[mode === 'push' ? 'pushState' : 'replaceState']({}, '', url);
      }

      function getLoginUrl() {
        const url = new URL('/auth/github', apiBaseUrl);
        url.searchParams.set('returnTo', location.href);

        return url.toString();
      }

      function showAuthPanel() {
        wordle.classList.remove('htmlacademy');
        authPanel.hidden = false;
        wordleMain.hidden = true;
        userPanel.hidden = true;
        wordleActions.hidden = false;
        newGameButton.disabled = true;
        githubLogin.href = getLoginUrl();
      }

      function showGame(user) {
        authPanel.hidden = true;
        wordleMain.hidden = false;
        userPanel.hidden = false;
        wordleActions.hidden = false;
        newGameButton.disabled = false;
        userAvatar.src = user.avatarUrl || '';
        userName.textContent = user.name || user.login;
        userLink.href = user.htmlUrl || `https://github.com/${user.login}`;
        userLink.textContent = `@${user.login}`;
      }

      function showPlayScreen() {
        finalPanel.hidden = true;
        rules.hidden = false;
        gamePanel.hidden = false;
        wordleActions.hidden = false;
        newGameButton.disabled = false;
      }

      function showFinalScreen(progress) {
        wordle.classList.remove('htmlacademy');
        finalPanel.hidden = false;
        rules.hidden = true;
        gamePanel.hidden = true;
        gameOver = true;
        isSubmitting = false;
        currentGuess = '';
        answerLength = 0;
        guesses = [];
        keyStates = {};
        finalText.textContent = `Ты какой-то невероятный и прошёл игру до конца. Поздравляю ты угадал все ${progress.answers} слов.`;
        progressCount.textContent = `${progress.completed}/${progress.answers}`;
        wordLength.textContent = '0';
        attempts.textContent = `0/${MAX_ATTEMPTS}`;
        wordleActions.hidden = true;
        newGameButton.disabled = true;
        setStatus('');
        renderBoard();
        renderKeyboard();
        setGameUuidInUrl('', 'replace');
      }

      async function requestJson(path, options = {}) {
        const response = await fetch(`${apiBaseUrl}${path}`, {
          ...options,
          credentials: 'include',
          headers: {
            'content-type': 'application/json',
            ...options.headers,
          },
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(payload.error || 'API request failed.');
        }

        return payload;
      }

      function setStatus(message, tone = '') {
        statusText.textContent = message;
        status.dataset.tone = tone;
        statusNextButton.hidden = tone !== 'success';
      }

      function updateMeta() {
        wordLength.textContent = String(answerLength || 0);
        attempts.textContent = `${guesses.length}/${MAX_ATTEMPTS}`;
      }

      function normalizeServerGuess(guess) {
        return {
          word: guess.value,
          score: guess.result.map((item) => item.state),
        };
      }

      function getTileState(rowIndex, charIndex, char) {
        if (rowIndex < guesses.length) {
          return guesses[rowIndex].score[charIndex];
        }

        if (rowIndex === guesses.length && char) {
          return 'filled';
        }

        return '';
      }

      function renderBoard() {
        board.style.setProperty('--word-length', answerLength || 5);
        board.textContent = '';

        for (let rowIndex = 0; rowIndex < MAX_ATTEMPTS; rowIndex += 1) {
          const row = document.createElement('div');
          row.className = 'board__row';

          const submittedGuess = guesses[rowIndex]?.word ?? '';
          const rowText = submittedGuess || (rowIndex === guesses.length ? currentGuess : '');

          for (let charIndex = 0; charIndex < (answerLength || 5); charIndex += 1) {
            const tile = document.createElement('span');
            const char = rowText[charIndex] ?? '';
            const state = getTileState(rowIndex, charIndex, char);

            tile.className = 'tile';
            tile.textContent = char;
            tile.setAttribute('aria-label', char || 'пусто');

            if (state) {
              tile.dataset.state = state;
            }

            row.append(tile);
          }

          board.append(row);
        }
      }

      function updateKeyState(char, state) {
        if (!char || !STATE_RANK[state]) {
          return;
        }

        const current = keyStates[char];

        if (!current || STATE_RANK[state] > STATE_RANK[current]) {
          keyStates[char] = state;
        }
      }

      function renderKeyboard() {
        keyboard.textContent = '';

        for (const keys of KEY_ROWS) {
          const row = document.createElement('div');
          row.className = 'keyboard__row';

          for (const key of keys) {
            const button = document.createElement('button');
            button.className = key.length > 1 ? 'key key--wide' : 'key';
            button.type = 'button';
            button.dataset.key = key;
            button.textContent = key === 'backspace' ? '⌫' : key;
            button.setAttribute('aria-label', key);

            if (keyStates[key]) {
              button.dataset.state = keyStates[key];
            }

            row.append(button);
          }

          keyboard.append(row);
        }
      }

      function createLeaderboardItem(row, isCurrent) {
        const item = document.createElement('tr');
        const rankCell = document.createElement('td');
        const playerCell = document.createElement('td');
        const scoreCell = document.createElement('td');
        const rank = document.createElement('span');
        const link = document.createElement('a');
        const score = document.createElement('span');

        item.className = `leaderboard__row${isCurrent ? ' leaderboard__row--current' : ''}`;
        rank.className = 'leaderboard__rank';
        link.className = 'leaderboard__link';
        score.className = 'leaderboard__score';

        rank.textContent = `#${row.rank}`;
        link.href = row.htmlUrl || `https://github.com/${row.login}`;
        link.target = '_blank';
        link.rel = 'noreferrer';
        link.textContent = row.name || row.login;
        score.textContent = String(row.score);
        rankCell.append(rank);
        playerCell.append(link);
        scoreCell.append(score);
        item.append(rankCell, playerCell, scoreCell);

        return item;
      }

      function createLeaderboardMessage(message) {
        const row = document.createElement('tr');
        const cell = document.createElement('td');

        cell.className = 'leaderboard__gap';
        cell.colSpan = 3;
        cell.textContent = message;
        row.append(cell);

        return row;
      }

      function renderLeaderboard(data) {
        const rows = [...data.top];
        const current = data.currentUser;
        const hasCurrentInTop = current && rows.some((row) => row.id === current.id);

        leaderboard.textContent = '';

        if (!rows.length && !current) {
          leaderboard.append(createLeaderboardMessage('Пока никого нет.'));
          return;
        }

        for (const row of rows) {
          leaderboard.append(createLeaderboardItem(row, current?.id === row.id));
        }

        if (current && !hasCurrentInTop) {
          leaderboard.append(createLeaderboardMessage('...'), createLeaderboardItem(current, true));
        }
      }

      function rebuildKeyStates() {
        keyStates = {};

        for (const guess of guesses) {
          for (let index = 0; index < guess.word.length; index += 1) {
            updateKeyState(guess.word[index], guess.score[index]);
          }
        }
      }

      function applyGame(game) {
        wordle.classList.toggle('htmlacademy', game.theme === 'htmlacademy');
        gameUuid = game.gameUuid;
        wordUuid = game.wordUuid;
        answerLength = game.wordLength;
        currentGuess = '';
        guesses = game.guesses.map(normalizeServerGuess);
        gameOver = game.status !== 'active';
        isSubmitting = false;
        rebuildKeyStates();

        if (game.status === 'won') {
          setStatus('Молодец! CSS-фича угадана', 'success');
        } else if (game.status === 'lost') {
          setStatus('Попытки закончились.', 'danger');
        } else {
          setStatus('');
        }

        updateMeta();
        renderBoard();
        renderKeyboard();
      }

      function getGuessErrorMessage(error) {
        if (error.message.includes('characters long')) {
          return `Нужно ${answerLength} символов.`;
        }

        if (error.message.includes('CSS dictionary')) {
          return 'Этого слова нет в словаре.';
        }

        if (error.message.includes('finished')) {
          return 'Эта загадка уже завершена.';
        }

        return 'Не получилось отправить попытку. Проверьте соединение.';
      }

      function getGameLoadErrorMessage(error) {
        if (error.message.includes('All questions are completed')) {
          return 'Все вопросы пройдены. CSS словарь побежден.';
        }

        return 'Не получилось загрузить загадку.';
      }

      async function handleGameLoadError(error) {
        if (error.message.includes('All questions are completed')) {
          const progress = await loadProgress();

          if (progress) {
            showFinalScreen(progress);
            return;
          }
        }

        setStatus(getGameLoadErrorMessage(error), 'danger');
        gameOver = true;
      }

      async function submitGuess() {
        if (gameOver || isSubmitting) {
          return;
        }

        if (currentGuess.length !== answerLength) {
          setStatus(`Нужно ${answerLength} символов.`, 'danger');
          return;
        }

        try {
          isSubmitting = true;
          setStatus('Проверяю...');

          const guessValue = currentGuess;
          const game = await requestJson(`/games/${gameUuid}/guess`, {
            method: 'POST',
            body: JSON.stringify({
              wordUuid,
              guess: guessValue,
            }),
          });
          const score = game.lastResult.map((item) => item.state);

          for (const item of game.lastResult) {
            updateKeyState(item.char, item.state);
          }

          guesses.push({
            word: guessValue,
            score,
          });

          if (game.status === 'won') {
            gameOver = true;
            setStatus('Молодец! Слово угадано', 'success');
            const progress = await loadProgress();

            if (progress && progress.completed >= progress.answers) {
              showFinalScreen(progress);
            }

            loadLeaderboard();
          } else if (game.status === 'lost') {
            gameOver = true;
            setStatus('Попытки закончились.', 'danger');
          } else {
            setStatus('Еще попытка.');
          }

          currentGuess = '';
          updateMeta();
          renderBoard();
          renderKeyboard();
        } catch (error) {
          setStatus(getGuessErrorMessage(error), 'danger');
        } finally {
          isSubmitting = false;
        }
      }

      function addChar(char) {
        if (gameOver || isSubmitting || !answerLength || !VALID_INPUT.test(char) || currentGuess.length >= answerLength) {
          return;
        }

        currentGuess += char;
        setStatus('');
        renderBoard();
      }

      function removeChar() {
        if (gameOver || isSubmitting || !currentGuess) {
          return;
        }

        currentGuess = currentGuess.slice(0, -1);
        setStatus('');
        renderBoard();
      }

      function handleKey(key) {
        const normalizedKey = key.toLowerCase();

        if (normalizedKey === 'enter') {
          submitGuess();
          return;
        }

        if (normalizedKey === 'backspace') {
          removeChar();
          return;
        }

        addChar(normalizedKey);
      }

      async function loadProgress() {
        try {
          const progress = await requestJson('/progress');
          progressCount.textContent = `${progress.completed}/${progress.answers}`;
          return progress;
        } catch {
          progressCount.textContent = '...';
          return null;
        }
      }

      async function loadLeaderboard() {
        try {
          renderLeaderboard(await requestJson('/leaderboard'));
        } catch {
          leaderboard.textContent = '';
          leaderboard.append(createLeaderboardMessage('Не удалось загрузить рейтинг.'));
        }
      }

      async function loadMe() {
        const result = await requestJson('/me');

        if (!result.user) {
          showAuthPanel();
          await loadLeaderboard();
          return false;
        }

        showGame(result.user);
        const progress = await loadProgress();
        await loadLeaderboard();

        if (progress && progress.completed >= progress.answers) {
          showFinalScreen(progress);
          return false;
        }

        showPlayScreen();
        return true;
      }

      async function loadGame(nextGameUuid) {
        showPlayScreen();
        gameOver = true;
        setStatus('Загружаю загадку...');

        const game = await requestJson(`/games/${nextGameUuid}`);
        applyGame(game);
      }

      async function startGame(historyMode = 'replace') {
        showPlayScreen();
        gameOver = true;
        setStatus('Загружаю загадку...');

        const game = await requestJson('/games', {
          method: 'POST',
        });

        setGameUuidInUrl(game.gameUuid, historyMode);
        applyGame(game);
      }

      async function bootGame() {
        const urlGameUuid = getGameUuidFromUrl();

        if (urlGameUuid) {
          await loadGame(urlGameUuid);
          return;
        }

        await startGame('replace');
      }

      function startNextGame() {
        startGame('push').catch(handleGameLoadError);
      }

      keyboard.addEventListener('click', (event) => {
        const button = event.target.closest('[data-key]');

        if (!button) {
          return;
        }

        handleKey(button.dataset.key);
      }, { signal: controller.signal });

      document.addEventListener('keydown', (event) => {
        if (event.metaKey || event.ctrlKey || event.altKey) {
          return;
        }

        if (event.key === 'Enter' || event.key === 'Backspace' || VALID_INPUT.test(event.key.toLowerCase())) {
          event.preventDefault();
          void handleKey(event.key);
        }
      }, { signal: controller.signal });

      newGameButton.addEventListener('click', startNextGame, { signal: controller.signal });
      statusNextButton.addEventListener('click', startNextGame, { signal: controller.signal });

      logoutButton.addEventListener('click', () => {
        requestJson('/auth/logout', { method: 'POST' }).finally(() => {
          gameOver = true;
          progressCount.textContent = '...';
          showAuthPanel();
          loadLeaderboard();
        });
      }, { signal: controller.signal });

      window.addEventListener('popstate', () => {
        const urlGameUuid = getGameUuidFromUrl();

        if (!urlGameUuid) {
          startGame('replace').catch(handleGameLoadError);
          return;
        }

        loadGame(urlGameUuid).catch(() => {
          setStatus('Не получилось открыть загадку из URL.', 'danger');
          gameOver = true;
        });
      }, { signal: controller.signal });

      renderBoard();
      renderKeyboard();
      loadMe()
        .then((isAuthenticated) => {
          if (!isAuthenticated) {
            return;
          }

          bootGame().catch(handleGameLoadError);
        })
        .catch(() => {
          showAuthPanel();
          loadLeaderboard();
        });
    </script>
  </body>
</html>
