---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('digest'))
  .filter(post => !post.data.isHidden)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featuredPost, ...otherPosts] = posts;

const groupedPosts = otherPosts.reduce((groups, post) => {
  const date = new Date(post.data.pubDate);
  const month = date.toLocaleDateString('ru-RU', { month: 'long', year: 'numeric' });
  const capitalizedMonth = month.charAt(0).toUpperCase() + month.slice(1);
  if (!groups[capitalizedMonth]) {
    groups[capitalizedMonth] = [];
  }
  groups[capitalizedMonth].push(post);
  return groups;
}, {} as Record<string, typeof otherPosts>);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .featured-post {
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
        margin-bottom: var(--space-3xl);
        padding: clamp(1.5rem, 1.1rem + 2.4vw, 3rem);
        background:
          radial-gradient(circle at 90% 12%, rgba(243, 191, 31, 0.45), transparent 52%),
          radial-gradient(circle at 4% 94%, rgba(115, 182, 72, 0.22), transparent 58%),
          var(--paper-color);
        border-radius: var(--radius-lg);
        border: 2px solid rgba(var(--line), 0.56);
        box-shadow: var(--shadow-soft);
        position: relative;
        overflow: hidden;
        animation: rise-in 0.5s ease both;
      }

      .featured-title {
        font-size: var(--text-4xl);
        color: rgb(var(--ink));
        margin: 0;
        line-height: 1.03;
        max-width: 12ch;
      }

      .featured-date {
        color: rgb(var(--muted));
        font-size: var(--text-sm);
        letter-spacing: 0.09em;
        font-family: var(--font-accent);
        text-transform: uppercase;
        margin: 0;
      }

      .featured-description {
        font-size: var(--text-md);
        color: rgb(var(--ink-soft));
        margin: 0 0 var(--space-md) 0;
        max-width: 60ch;
      }

      .featured-link {
        text-decoration: none;
      }

      .featured-link:hover .featured-title {
        color: var(--accent-red);
      }

      .featured-read-more {
        align-self: flex-start;
        color: #fff9ec;
        background: linear-gradient(120deg, var(--accent-dark), var(--accent));
        font-size: var(--text-sm);
        font-weight: 800;
        letter-spacing: 0.03em;
        padding: 0.55rem 1.1rem;
        border-radius: 999px 999px 999px 0;
        border: 2px solid rgba(110, 43, 10, 0.2);
        text-decoration: none;
        transition: transform 0.2s ease, filter 0.2s ease;
      }

      .featured-read-more:hover {
        transform: translateY(-2px);
        filter: saturate(115%);
      }

      .posts-grid__heading {
        font-size: var(--text-4xl);
        margin-bottom: var(--space-xl);
        color: rgb(var(--ink));
      }

      .posts-grid {
        max-width: 1440px;
        margin-inline: auto;
      }

      .grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space-lg);
      }

      .grid-post {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        padding: var(--space-lg);
        background: var(--paper-color);
        border: 2px solid rgba(var(--line), 0.48);
        border-radius: var(--radius-md);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 4px 10px rgba(93, 59, 34, 0.08);
        animation: rise-in 0.4s ease both;
      }

      .grid-post:hover {
        transform: translateY(-4px) rotate(-0.3deg);
        box-shadow: 0 12px 24px rgba(93, 59, 34, 0.16);
      }

      .grid-post__title {
        font-size: var(--text-xl);
        margin: 0;
        color: rgb(var(--ink));
        line-height: 1.12;
      }

      .grid-post__date {
        color: rgb(var(--muted));
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        font-family: var(--font-accent);
        text-transform: uppercase;
        margin: 0;
      }

      .grid-post__description {
        font-size: var(--text-sm);
        color: rgb(var(--ink-soft));
        margin: 0;
      }

      .grid-post__link {
        text-decoration: none;
      }

      .grid-post__link:hover .grid-post__title {
        color: var(--accent-red);
      }

      .post-tag {
        align-self: flex-start;
        font-size: var(--text-xs);
        font-weight: 700;
        color: var(--accent-dark);
        background: rgba(243, 191, 31, 0.45);
        padding: 0.24rem 0.62rem;
        border-radius: 999px 999px 999px 0;
        border: 1px solid rgba(var(--line), 0.45);
        text-transform: uppercase;
        letter-spacing: 0.09em;
        font-family: var(--font-accent);
      }

      .month-group {
        margin-bottom: var(--space-3xl);
      }

      .month-header {
        font-size: var(--text-lg);
        font-weight: 800;
        color: rgb(var(--ink-soft));
        margin: 0 0 var(--space-xl) 0;
        padding-bottom: var(--space-xs);
        border-bottom: 3px dashed rgba(var(--line), 0.55);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-accent);
      }

      @media (max-width: 720px) {
        main {
          margin-inline: 0;
          padding-inline: var(--space-sm);
        }

        .featured-post {
          padding-inline: var(--space-md);
        }

        .grid-post {
          padding-inline: var(--space-md);
        }

        .featured-title {
          font-size: var(--text-3xl);
        }
      }

      @media (max-width: 980px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
	</head>
	<body>
		<Header />
		<main>

        <h1 class="sr-only">Статьи</h1>
        {featuredPost && (
          <section class="featured-post">
            <span class="post-tag">Дайджест</span>
            <a href={`/${featuredPost.slug}/`} class="featured-link">
              <h2 class="featured-title" transition:name={`title-${featuredPost.slug}`}>{featuredPost.data.title}</h2>
            </a>
            <p class="featured-date">
              {new Date(featuredPost.data.pubDate).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <p class="featured-description">{featuredPost.data.description}</p>
            <a href={`/${featuredPost.slug}/`} class="featured-read-more">Читать дальше →</a>
          </section>
        )}

        <section class="posts-grid">
          <h2 class="posts-grid__heading">Другие выпуски</h2>

          {Object.entries(groupedPosts).map(([month, posts]) => (
            <div class="month-group">
              <h3 class="month-header">{month}</h3>
              <ul class="grid">
                {posts.map((post) => (
                  <li class="grid-post">
                    <span class="post-tag">Дайджест</span>
                    <a href={`/${post.slug}/`} class="grid-post__link">
                      <h3 class="grid-post__title" transition:name={`title-${post.slug}`}>{post.data.title}</h3>
                    </a>
                    <p class="grid-post__date">
                      {new Date(post.data.pubDate).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </p>
                    <p class="grid-post__description">{post.data.description}</p>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>
		</main>
		<Footer />
	</body>
</html>
